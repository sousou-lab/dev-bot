# Core runtime
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STATUS_CHANNEL_ID=
REQUIREMENTS_CHANNEL_ID=
WORKSPACE_ROOT=/tmp/dev-bot-workspaces
STATE_DIR=./runs
LOG_LEVEL=INFO

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=
GITHUB_OWNER=
GITHUB_REPO=

# Optional: GitHub Projects v2 state sync
GITHUB_PROJECT_ID=
GITHUB_PROJECT_STATE_FIELD_ID=
GITHUB_PROJECT_STATE_OPTION_IDS={"Backlog":"","Ready":"","In Progress":"","Human Review":"","Rework":"","Merging":"","Done":"","Blocked":"","Cancelled":""}
GITHUB_PROJECT_PLAN_FIELD_ID=
GITHUB_PROJECT_PLAN_OPTION_IDS={"Not Started":"","Drafted":"","Approved":"","Changes Requested":""}

# Planning lane
PLANNING_LANE_ENABLED=true
ANTHROPIC_API_KEY=
ENABLE_REQUIREMENTS_FLOW_FALLBACK=true
REQUIREMENTS_AGENT_TIMEOUT_SECONDS=90

# Codex local login mode
CODEX_AUTH_MODE=chatgpt_login
CODEX_BIN=codex
CODEX_APP_SERVER_COMMAND=codex app-server
CODEX_MODEL=codex-mini-latest

# Execution controls
MAX_IMPLEMENTATION_ITERATIONS=5
MAX_CONCURRENT_RUNS=1
APPROVAL_TIMEOUT_SECONDS=900
SCHEDULER_POLL_INTERVAL_SECONDS=15

# Legacy compatibility only; prefer STATE_DIR
RUNS_ROOT=./runs

# Optional when using Codex CLI manual login instead of API-key auth
OPENAI_API_KEY=
